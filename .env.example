# Supabase project credentials.
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Web Push public key (safe to expose in the browser — pair it with
# VAPID_PRIVATE_KEY set only as an Edge Function secret, never here).
# Generate a pair with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Never put ASHTECH_API_KEY, SUPABASE_SERVICE_ROLE_KEY, or
# VAPID_PRIVATE_KEY here — those belong ONLY in Supabase Edge Function
# secrets (supabase secrets set ...), never in this app's env, since this
# app's code ships to the browser.
#
# Edge Function secrets required:
#   ASHTECH_API_KEY        — Ashtech Pay Direct API key
#   SUPABASE_SERVICE_ROLE_KEY  (auto-provided by Supabase)
#   SUPABASE_URL               (auto-provided by Supabase)
#   VAPID_PUBLIC_KEY        — same value as VITE_VAPID_PUBLIC_KEY above
#   VAPID_PRIVATE_KEY       — from `npx web-push generate-vapid-keys`
#   VAPID_SUBJECT           — e.g. mailto:support@yourdomain.com
#   SITE_URL                — e.g. https://sellizi.app (used by the sitemap function)
